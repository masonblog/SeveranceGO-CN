{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "severancego-cn",
  "compatibility_date": "2026-05-15",
  "workers_dev": false,
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "severance.masonhu.cc",
      "custom_domain": true
    }
  ]
}
